# QStash signing keys (for cron job verification)
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# Optional: Render-hosted proxy for Google News URL decoding (avoids Vercel IP blocks)
GNEWS_PROXY_URL=""
GNEWS_PROXY_KEY=""
